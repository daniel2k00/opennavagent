# Pick one LLM provider. OpenNavAgent is model-agnostic via Vercel AI SDK.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which model to use (format: "provider:model")
# Examples: "anthropic:claude-sonnet-4", "openai:gpt-4o-mini"
# Default: anthropic:claude-sonnet-4
OPENNAVAGENT_MODEL=anthropic:claude-sonnet-4

# Valhalla routing engine URL (spun up by `npm run valhalla:up`)
VALHALLA_URL=http://localhost:8002

# HTTP server port
PORT=3000
